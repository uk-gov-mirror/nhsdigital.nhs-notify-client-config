{
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "catalog:lint",
    "@eslint/js": "catalog:lint",
    "@stylistic/eslint-plugin": "catalog:lint",
    "@tsconfig/node22": "catalog:tools",
    "@types/jest": "catalog:test",
    "esbuild": "catalog:tools",
    "eslint": "catalog:lint",
    "eslint-config-airbnb-extended": "catalog:lint",
    "eslint-config-next": "catalog:frontend",
    "eslint-config-prettier": "catalog:lint",
    "eslint-import-resolver-typescript": "catalog:lint",
    "eslint-plugin-html": "catalog:lint",
    "eslint-plugin-import-x": "catalog:lint",
    "eslint-plugin-jest": "catalog:lint",
    "eslint-plugin-json": "catalog:lint",
    "eslint-plugin-jsx-a11y": "catalog:lint",
    "eslint-plugin-no-relative-import-paths": "catalog:lint",
    "eslint-plugin-prettier": "catalog:lint",
    "eslint-plugin-react": "catalog:lint",
    "eslint-plugin-security": "catalog:lint",
    "eslint-plugin-sonarjs": "catalog:lint",
    "eslint-plugin-sort-destructure-keys": "catalog:lint",
    "eslint-plugin-unicorn": "catalog:lint",
    "jest": "catalog:test",
    "jest-environment-jsdom": "catalog:test",
    "jest-html-reporter": "catalog:test",
    "jest-mock-extended": "catalog:test",
    "lcov-result-merger": "catalog:test",
    "ts-jest": "catalog:test",
    "ts-node": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript-eslint": "catalog:lint"
  },
  "name": "nhs-notify-client-config",
  "overrides": {
    "fast-xml-parser": "5.5.7",
    "js-yaml": "4.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "scripts": {
    "build": "pnpm --filter ./frontend run build",
    "build-lambda": "pnpm -r --filter './lambdas/*' run --if-present lambda-build",
    "deps:check": "pnpm dlx syncpack lint --dependency-types prod,dev --source 'package.json' --source 'docs/package.json' --source 'frontend/package.json' --source 'packages/event-builder/package.json' --source 'packages/events/package.json'",
    "deps:sync": "pnpm dlx syncpack fix --dependency-types prod,dev --source 'package.json' --source 'docs/package.json' --source 'frontend/package.json' --source 'packages/event-builder/package.json' --source 'packages/events/package.json'",
    "dev": "pnpm --filter ./frontend run dev",
    "generate-dependencies": "pnpm -r run --if-present generate-dependencies || true",
    "lint": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' pnpm -r run --if-present lint",
    "lint:fix": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' pnpm -r run --if-present lint:fix",
    "start": "pnpm --filter ./frontend run start",
    "test:ui": "pnpm run build && if [ -f tests/test-team/package.json ]; then pnpm --filter ./tests/test-team run test:local-ui; else echo 'No tests/test-team workspace configured'; fi",
    "test:unit": "pnpm -r run --if-present test:unit",
    "typecheck": "pnpm -r run --if-present typecheck"
  },
  "version": "1.0.0"
}
