{
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "catalog:frontend",
    "aws-amplify": "catalog:frontend",
    "next": "catalog:frontend",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend"
  },
  "devDependencies": {
    "@testing-library/dom": "catalog:frontend",
    "@testing-library/jest-dom": "catalog:frontend",
    "@testing-library/react": "catalog:frontend",
    "@testing-library/user-event": "catalog:frontend",
    "@types/jest": "catalog:test",
    "@types/node": "catalog:tools",
    "@types/react": "catalog:frontend",
    "@types/react-dom": "catalog:frontend",
    "jest": "catalog:test",
    "jest-environment-jsdom": "catalog:test",
    "jest-html-reporter": "catalog:test",
    "jest-mock-extended": "catalog:test",
    "sass": "catalog:frontend",
    "ts-jest": "catalog:test",
    "typescript": "catalog:tools"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ]
  },
  "name": "nhs-notify-client-config-frontend",
  "private": true,
  "scripts": {
    "app:start": "pnpm run start > /tmp/nhs-notify-frontend.log 2>&1 & echo $! > /tmp/nhs-notify-frontend.pid",
    "app:stop": "if [ -f /tmp/nhs-notify-frontend.pid ]; then kill $(cat /tmp/nhs-notify-frontend.pid) || true; rm -f /tmp/nhs-notify-frontend.pid; fi",
    "app:wait": "wait-on -l http://localhost:3000/auth",
    "build": "next build",
    "dev": "next dev",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "start": "next start",
    "test:coverage": "jest --coverage",
    "test:unit": "jest",
    "typecheck": "tsc --noEmit"
  },
  "version": "0.1.0"
}
